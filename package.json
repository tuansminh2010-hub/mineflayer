const mineflayer = require('mineflayer')

const config = {
    host: 'hpdvc.aternos.me',
    port: 14709,
    username: 'AFK_Bot',
    auth: 'offline',

    // Nếu server chạy phiên bản khác thì sửa lại
    // Ví dụ: '1.20.1', '1.21.1', '1.21.8'
    version: 1.26.2
}

let bot
let antiAfk

function startBot() {

    bot = mineflayer.createBot(config)

    bot.once('spawn', () => {

        console.log('=================================')
        console.log(' Bot đã vào server!')
        console.log('=================================')

        // Nếu server dùng AuthMe thì bỏ // ở dòng dưới
        // setTimeout(() => bot.chat('/login MATKHAU'), 3000)

        // Nếu bot chưa có tài khoản thì dùng dòng dưới 1 lần
        // setTimeout(() => bot.chat('/register MATKHAU MATKHAU'), 3000)

        // Lời chào (có thể xóa)
        setTimeout(() => {
            bot.chat('Xin chào!')
        }, 5000)

        if (antiAfk) clearInterval(antiAfk)

        antiAfk = setInterval(() => {

            console.log(' Anti AFK')

            // Nhảy
            bot.setControlState('jump', true)

            setTimeout(() => {
                bot.setControlState('jump', false)
            }, 500)

            // Xoay đầu ngẫu nhiên
            bot.look(
                Math.random() * Math.PI * 2,
                (Math.random() - 0.5) * 0.5,
                true
            )

        }, 30000)

    })

    bot.on('chat', (username, message) => {

        if (username === bot.username) return

        console.log(`[CHAT] ${username}: ${message}`)

    })

    bot.on('kicked', reason => {
        console.log(' Bị kick:')
        console.log(reason)
    })

    bot.on('error', err => {
        console.log(' Lỗi:', err.message)
    })

    bot.on('end', () => {

        console.log(' Mất kết nối')
        console.log(' Kết nối lại sau 5 giây...')

        if (antiAfk) {
            clearInterval(antiAfk)
            Timeout = 9999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999
        }

        setTimeout(startBot, 5000)

    })

}

startBot()
